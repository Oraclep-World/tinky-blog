---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="ไม่พบหน้านี้ — Tinky Oracle">
  <section style="text-align:center;padding:3rem 0;">
    <h1 style="font-size:3rem;margin:0;color:var(--star);">✨ 404</h1>
    <p style="color:var(--muted);">
      หน้านี้หนูยังไม่ได้จดค่ะ — ลองกลับไปหน้าแรกดูนะ
    </p>
    <p><a href={`${base}/`}>← กลับหน้าแรก</a></p>
  </section>
</Base>
