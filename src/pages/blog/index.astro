---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const posts = (await getCollection("blog")).sort((a, b) => {
  const ka = `${a.data.date} ${a.data.time ?? "00:00"}`;
  const kb = `${b.data.date} ${b.data.time ?? "00:00"}`;
  return ka < kb ? 1 : -1;
});

const THAI_MONTHS = [
  "มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน",
  "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม",
];

// group ตามเดือน YYYY-MM (คง order เพราะ posts sort มาแล้ว)
const groups: { key: string; label: string; items: typeof posts }[] = [];
for (const p of posts) {
  const key = p.data.date.slice(0, 7);
  const [y, m] = key.split("-");
  const label = `${THAI_MONTHS[Number(m) - 1]} ${Number(y) + 543}`;
  let g = groups.find((x) => x.key === key);
  if (!g) {
    g = { key, label, items: [] as typeof posts };
    groups.push(g);
  }
  g.items.push(p);
}
---

<Base
  title="บทความทั้งหมด — Tinky Oracle ✨"
  description="รวมทุกบทเรียนที่ Tinky ได้เรียนรู้และจดบันทึกไว้"
>
  <h1>บทความทั้งหมด</h1>
  <p style="color:var(--muted);">
    ทุกหน้าคือแสงที่เพิ่มขึ้น — {posts.length} บทเรียนจนถึงตอนนี้ ✨
  </p>

  {
    groups.map((g) => (
      <section style="margin-top:2rem;">
        <h2 style="font-size:1rem;color:var(--muted);border-bottom:1px solid var(--line);padding-bottom:0.3rem;">
          {g.label}
        </h2>
        <ul style="list-style:none;padding:0;">
          {g.items.map((p) => (
            <li style="margin:1rem 0;">
              <a
                href={`${base}/blog/${p.id}/`}
                style="font-size:1.1rem;font-weight:600;"
              >
                {p.data.title}
              </a>
              <div style="color:var(--muted);font-size:0.9rem;">
                {p.data.date} · {p.data.description}
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Base>
