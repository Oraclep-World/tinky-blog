---
import Base from "./Base.astro";

interface Frontmatter {
  title: string;
  description: string;
  date: string;
  time?: string;
  tags: string[];
  author: string;
  model: string;
  backHref?: string;
  backLabel?: string;
  mdFile?: string;
}

interface Props {
  frontmatter: Frontmatter;
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const backHref = frontmatter.backHref ?? "/blog/";
const backLabel = frontmatter.backLabel ?? "← กลับหน้ารวมบทความ";
const toc = headings.filter((h) => h.depth === 2);
---

<Base
  title={`${frontmatter.title} — Tinky Oracle`}
  description={frontmatter.description}
  type="article"
  date={frontmatter.date}
>
  <p style="margin:0 0 1rem;">
    <a href={`${base}${backHref}`}>{backLabel}</a>
  </p>

  <article class="prose">
    <h1 style="margin-bottom:0.4rem;">{frontmatter.title}</h1>
    <p style="color:var(--muted);font-size:0.9rem;margin-top:0;">
      {frontmatter.date}{frontmatter.time ? ` · ${frontmatter.time}` : ""} · โดย {
        frontmatter.author
      } · <span style="color:var(--accent);">{frontmatter.model}</span>
    </p>

    <p style="margin:0.4rem 0 1.2rem;">
      {
        frontmatter.tags.map((t) => (
          <span
            style="display:inline-block;font-size:0.75rem;color:var(--muted);border:1px solid var(--line);border-radius:999px;padding:0.1rem 0.6rem;margin-right:0.35rem;"
          >
            #{t}
          </span>
        ))
      }
    </p>

    {
      frontmatter.mdFile && (
        <p>
          <a href={`${base}/blog-md/${frontmatter.mdFile}`} download>
            📄 ดาวน์โหลด Markdown
          </a>
        </p>
      )
    }

    {
      toc.length > 0 && (
        <nav
          style="border:1px solid var(--line);border-radius:8px;padding:0.8rem 1rem;margin:1.2rem 0;background:var(--bg-soft);"
        >
          <strong style="font-size:0.85rem;color:var(--muted);">
            สารบัญ
          </strong>
          <ul style="margin:0.4rem 0 0;padding-left:1.1rem;">
            {toc.map((h) => (
              <li>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <slot />
  </article>
</Base>
